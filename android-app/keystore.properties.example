# Copy this file to keystore.properties (same folder) and fill in the real
# values. keystore.properties is gitignored — never commit real passwords.
# The actual signing keystore for this app already exists locally at
# android-app/coinquest-release.jks — back it up together with
# keystore.properties somewhere safe (password manager / encrypted backup).
# Losing both means you can no longer publish updates under this app identity.
storeFile=coinquest-release.jks
storePassword=REPLACE_ME
keyAlias=coinquest
keyPassword=REPLACE_ME
