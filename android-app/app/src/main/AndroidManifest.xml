<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.coinquest.app">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Native game-time enforcement (backlog: real purchased Minecraft, not the
         web-embedded games): proven via the standalone ScreenTimeSpike project
         (AccessibilityService foreground-detection + performGlobalAction(HOME),
         confirmed working on a real device) before being integrated here. -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- AN5: re-arm the daily chore-reminder alarm after a reboot clears it. -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <queries>
        <package android:name="com.mojang.minecraftpe" />
    </queries>

    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <!-- AN7 (ANDROID-APP-PLAN.md, signing/hardening review):
         allowBackup=false, because the parent PIN and any local-only family
         cache live in the WebView's storage; Android's automatic cloud/adb
         backup would otherwise silently carry them onto a NEW device on
         restore, which is exactly the kind of surprise a PIN gate exists to
         prevent. networkSecurityConfig was authored (see
         network_security_config.xml) but never actually referenced here, so
         it had zero effect; wired in now, though usesCleartextTraffic=false
         already blocks plaintext HTTP app-wide on its own, so this mainly
         makes the per-domain intent explicit rather than leaving unused
         config in the tree. -->
    <application
        android:allowBackup="false"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.CoinQuest"
        android:usesCleartextTraffic="false"
        android:networkSecurityConfig="@xml/network_security_config"
        android:hardwareAccelerated="true">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.CoinQuest.Splash"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".GameTimeAccessibilityService"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/game_time_accessibility_config" />
        </service>

        <service
            android:name=".GameTimeOverlayService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="game-time-enforcement-overlay" />
        </service>

        <!-- Device-owner admin component. Provisioned once per device with
             "adb shell dpm set-device-owner" (component
             com.coinquest.app.debug/com.coinquest.app.CoinQuestDeviceAdminReceiver
             for the family-debug build) on a factory-reset device with no
             accounts. This is what grants GamePolicyManager the power to
             setPackagesSuspended the purchased native game (Minecraft) unless a
             coin-bought session is active: the enforcement mechanism that
             replaced the AccessibilityService, which Google Family Link
             force-disables. -->
        <receiver
            android:name=".CoinQuestDeviceAdminReceiver"
            android:permission="android.permission.BIND_DEVICE_ADMIN"
            android:exported="true">
            <meta-data
                android:name="android.app.device_admin"
                android:resource="@xml/device_admin" />
            <intent-filter>
                <action android:name="android.app.action.DEVICE_ADMIN_ENABLED" />
            </intent-filter>
        </receiver>

        <!-- AN5: daily chore-reminder alarm (ACTION_FIRE, targeted directly by
             ChoreReminderScheduler's PendingIntent) + BOOT_COMPLETED re-arm. -->
        <receiver android:name=".ReminderReceiver" android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
