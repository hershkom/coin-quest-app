{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "**/android-app/**",
      "android-app/**",
      "**/*.md",
      "**/*.ps1",
      "**/*.bat",
      "**/*.exe",
      "**/*.jar",
      "**/*.apk",
      "**/*.aab",
      "tests/**",
      "test-results/**",
      "playwright-report/**",
      "playwright.config.js",
      "package.json",
      "package-lock.json"
    ],
    "headers": [
      {
        "source": "/games/**",
        "headers": [{"key": "Cache-Control", "value": "public, max-age=604800"}]
      },
      {
        "source": "/static/**",
        "headers": [{"key": "Cache-Control", "value": "public, max-age=604800"}]
      }
    ]
  }
}
