{
  "rules": {
    ".read": false,
    ".write": false,

    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "families": {
      "$familyId": {
        ".read": "auth != null && root.child('users/'+auth.uid+'/familyId').val() === $familyId",
        ".write": "auth != null && root.child('users/'+auth.uid+'/familyId').val() === $familyId"
      }
    },

    "inviteCodes": {
      "$code": {
        ".read": "auth != null",
        ".write": "auth != null && newData.val() === root.child('users/'+auth.uid+'/familyId').val() && (!data.exists() || data.val() === root.child('users/'+auth.uid+'/familyId').val())"
      }
    }
  }
}
